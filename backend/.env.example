# Sunucu
PORT=8089
NODE_ENV=development
HOST=127.0.0.1

# Veritabani
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=ekosistem_sosyal

# Ekosistem API'leri (Artık social_projects tablosundan dinamik olarak yönetiliyor)
# Örnek: CONTENT_SOURCE_API_URL=http://localhost:8080/api

# Facebook
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Instagram (Facebook Business uzerinden)
IG_ACCOUNT_ID=
IG_ACCESS_TOKEN=
# Test postu icin public gorsel URL (dashboard ayarlarda bos birakilirsa kullanilir)
IG_TEST_IMAGE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=7044964180

# LinkedIn OAuth (callback URL dashboard ile ayni olmali, ornek: http://localhost:3004/oauth/linkedin/callback)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# X OAuth (callback ornek: http://localhost:3004/oauth/x/callback)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=

# AI Saglayicilar
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Google Cloud (Search Console + GA4 Data API — servis hesabi JSON tek satir)
# GA4 mulkune bu hesabi "Goruntuleyici" olarak ekleyin; GSC mulkune de kullanici ekleyin.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Ads API (kampanya okuma — OAuth refresh token + developer token)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_API_VERSION=v22

# DataForSEO (backlink domain ozeti — opsiyonel)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Genel
CORS_ORIGIN=http://localhost:3004,http://localhost:3035
JWT_SECRET=change-me-in-production
SEED_ADMIN_EMAIL=orhanguzell@gmail.com
SEED_ADMIN_PASSWORD=change-me-in-production
SEED_ADMIN_NAME=Orhan Guzel
TIMEZONE=Europe/Istanbul
APP_NAME=Ekosistem Sosyal Medya
CONTENT_SOURCE_LABEL=Tarim Ekosistem Haber Akisi
CONTENT_SOURCE_HASHTAGS=#tarim #dijitaltarim #ekosistem

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
